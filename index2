<script>
'use strict';
let _files=[], _D=null;

// ── BOOT ──────────────────────────────────────────
window.addEventListener('DOMContentLoaded', () => {
  const t = new Date(), fmt = d=>d.toISOString().split('T')[0];
  document.getElementById('A-date').textContent = t.toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'});
  document.getElementById('A-ref').textContent = 'CVE-SOL-'+String(Math.floor(Math.random()*9000)+1000);
  document.getElementById('A-appDate').value = fmt(t);
  const ex=new Date(t); ex.setDate(ex.getDate()+30);
  document.getElementById('A-expDate').value = fmt(ex);
  document.getElementById('B-sigDate').value = fmt(t);
  document.getElementById('C-llDate').value = fmt(t);

  // Signature pads
  initC('B-sig'); initC('C-sig'); initC('C-teSig',true);

  // File attachments
  const az=document.getElementById('B-az'), fi=document.getElementById('B-fi');
  az.addEventListener('dragover',e=>{e.preventDefault();az.classList.add('dv');});
  az.addEventListener('dragleave',()=>az.classList.remove('dv'));
  az.addEventListener('drop',e=>{e.preventDefault();az.classList.remove('dv');addF(e.dataTransfer.files);});
  fi.addEventListener('change',()=>{addF(fi.files);fi.value='';});

  // Detect view from URL hash
  boot();
  setTimeout(()=>document.getElementById('loadScreen').classList.add('hide'), 900);
});

function boot() {
  const raw = location.hash.slice(1);
  if (!raw) { show('A'); return; }
  try {
    _D = JSON.parse(decodeURIComponent(atob(raw)));
    const m = _D._m || 'A';
    show(m);
    if (m==='B') fillB(_D);
    if (m==='C') fillC(_D);
  } catch(e) { show('A'); }
}

// ── VIEWS ─────────────────────────────────────────
function show(m) {
  ['A','B','C'].forEach(v=>document.getElementById('v'+v).classList.remove('active'));
  document.getElementById('v'+m).classList.add('active');
  window.scrollTo(0,0);
}

// ── ENCODE / DECODE ───────────────────────────────
function enc(o){ return btoa(encodeURIComponent(JSON.stringify(o))); }
function lnk(o){ return location.href.split('#')[0]+'#'+enc(o); }
function gv(id){ const e=document.getElementById(id); return e?e.value:''; }

// ── VIEW A: GENERATE TENANT LINK ──────────────────
function genTenantLink() {
  if (!gv('A-addr').trim()||!gv('A-llName').trim()||!gv('A-teName').trim()||!gv('A-appDate').trim()) {
    toast('⚠ Fill required fields: Property Address, Landlord Name, Tenant Name, Approval Date'); return;
  }
  const p = {
    _m:'B',
    ref: document.getElementById('A-ref').textContent,
    addr:gv('A-addr'), llName:gv('A-llName'), llContact:gv('A-llContact'),
    teName:gv('A-teName'), teContact:gv('A-teContact'),
    tenDate:gv('A-tenDate'), appDate:gv('A-appDate'), expDate:gv('A-expDate'),
    panels:gv('A-panels'), restrict:gv('A-restrict'), note:gv('A-note'),
  };
  const url = lnk(p);
  document.getElementById('A-link').textContent = url;
  document.getElementById('A-teName-out').textContent = p.teName;
  document.getElementById('A-result').style.display='block';
  document.getElementById('A-result').scrollIntoView({behavior:'smooth',block:'center'});
  toast('✓ Tenant link generated — copy and send it!');
}

// ── VIEW B: FILL FROM LANDLORD DATA ───────────────
function fillB(d) {
  document.getElementById('B-ref').textContent = d.ref||'—';
  document.getElementById('B-issued').textContent = d.appDate||'—';
  document.getElementById('B-llNameHint').textContent = d.llName||'your landlord';
  const map = {addr:'B-addr',llName:'B-llName',llContact:'B-llContact',teName:'B-teName',
    teContact:'B-teContact',tenDate:'B-tenDate',appDate:'B-appDate',expDate:'B-expDate',panels:'B-panels'};
  Object.entries(map).forEach(([k,id])=>{ const e=document.getElementById(id); if(e) e.value=d[k]||''; });
  document.getElementById('B-maxP').textContent = d.panels||'3';
  if (d.restrict&&d.restrict.trim()) {
    document.getElementById('B-restrictBox').style.display='block';
    document.getElementById('B-restrictTxt').textContent=d.restrict;
  }
  if (d.note&&d.note.trim()) {
    document.getElementById('B-noteBox').style.display='block';
    document.getElementById('B-noteTxt').textContent=d.note;
  }
}

// ── VIEW B: TENANT SUBMITS ────────────────────────
function tenantSubmit() {
  if (!gv('B-installer').trim()){toast('⚠ Enter the licensed installer name/company');return;}
  if (!gv('B-location').trim()){toast('⚠ Enter the proposed installation location');return;}
  if (![1,2,3,4,5].every(n=>document.getElementById('c'+n).checked)){
    toast('⚠ You must tick all 5 acknowledgements before submitting');return;
  }
  if (!gv('B-print').trim()){toast('⚠ Print your full name in the signature section');return;}

  const orig = _D||{};
  const p = {
    ...orig, _m:'C',
    installer:gv('B-installer'), location:gv('B-location'),
    feeDate:gv('B-feeDate'), feeRef:gv('B-feeRef'),
    tePrint:gv('B-print'), teDate:gv('B-sigDate'),
    teSig:cvB64('B-sig'),
    checks:[1,2,3,4,5].map(n=>document.getElementById('c'+n).checked),
    attNames:_files.map(f=>f.name),
    subAt: new Date().toISOString(),
  };
  const url = lnk(p);
  document.getElementById('B-rlink').textContent = url;
  document.getElementById('B-llOut').textContent = orig.llName||'your landlord';
  document.getElementById('B-result').style.display='block';
  document.getElementById('B-result').scrollIntoView({behavior:'smooth',block:'center'});
  toast('✓ Submitted — send the review link to your landlord!');
  window._rlink=url;
}

// ── VIEW C: FILL FROM TENANT DATA ─────────────────
function fillC(d) {
  document.getElementById('C-ref').textContent = d.ref||'—';
  document.getElementById('C-sub').textContent = d.appDate||'—';
  const map={addr:'C-addr',llName:'C-llName',llContact:'C-llContact',teName:'C-teName',
    teContact:'C-teContact',tenDate:'C-tenDate',appDate:'C-appDate',expDate:'C-expDate',
    panels:'C-panels',installer:'C-installer',location:'C-location',
    feeDate:'C-feeDate',feeRef:'C-feeRef',tePrint:'C-tePrint',teDate:'C-teDate'};
  Object.entries(map).forEach(([k,id])=>{ const e=document.getElementById(id); if(e) e.value=d[k]||''; });
  if (d.checks) d.checks.forEach((v,i)=>{ const e=document.getElementById('C-c'+(i+1)); if(e) e.checked=v; });
  if (d.note&&d.note.trim()){
    document.getElementById('C-noteBox').style.display='block';
    document.getElementById('C-note').value=d.note;
  }
  if (d.attNames&&d.attNames.length){
    document.getElementById('C-attBox').style.display='block';
    document.getElementById('C-attList').innerHTML=d.attNames.map(n=>`<div>📄 ${n}</div>`).join('');
  }
  if (d.teSig) drawSig('C-teSig',d.teSig);
  // Pre-fill landlord name
  document.getElementById('C-llPrint').value = d.llName||'';
}

// ── VIEW C: LANDLORD DECIDES ──────────────────────
function decide(dec) {
  if (!gv('C-llPrint').trim()){toast('⚠ Print your full name to confirm decision');return;}
  const orig=_D||{};
  const p={
    ...orig, _m:'C', _final:true, decision:dec,
    comments:gv('C-comments'),
    llPrint:gv('C-llPrint'), llDate:gv('C-llDate'),
    llSig:cvB64('C-sig'),
    decidedAt:new Date().toISOString(),
  };
  const url=lnk(p);
  const ok=dec==='approved';
  document.getElementById('C-badge').textContent=ok?'APPROVED':'REJECTED';
  document.getElementById('C-badge').className='badge '+(ok?'b-ok':'b-no');
  document.getElementById('C-msg').innerHTML=ok
    ?`<strong>✓ Agreement Approved.</strong> Send the Final Record Link to the tenant. They must pay the <strong>₦100,000 caution deposit within 7 days</strong> to activate this permission.`
    :`<strong>Agreement Rejected.</strong> Your comments have been recorded. Send the link to the tenant to review and resubmit.`;
  document.getElementById('C-flink').textContent=url;
  document.getElementById('C-result').style.display='block';
  document.getElementById('C-result').scrollIntoView({behavior:'smooth',block:'center'});
  toast(ok?'✓ Approved — send Final Record Link to tenant!':'✓ Rejection recorded — send link to tenant.');
  window._flink=url;
}

// ── CANVAS ────────────────────────────────────────
function initC(id,ro) {
  const c=document.getElementById(id); if(!c)return;
  const ctx=c.getContext('2d');
  const rsz=()=>{
    const r=c.getBoundingClientRect(),dpr=window.devicePixelRatio||1;
    c.width=r.width*dpr; c.height=r.height*dpr;
    ctx.scale(dpr,dpr); ctx.strokeStyle='#111'; ctx.lineWidth=2; ctx.lineCap='round'; ctx.lineJoin='round';
  };
  rsz();
  if(ro){c.style.cursor='default';return;}
  let on=false,lx=0,ly=0;
  const gp=e=>{const r=c.getBoundingClientRect(),s=e.touches?e.touches[0]:e;return{x:s.clientX-r.left,y:s.clientY-r.top};};
  c.addEventListener('mousedown',e=>{on=true;const p=gp(e);lx=p.x;ly=p.y;});
  c.addEventListener('mousemove',e=>{if(!on)return;const p=gp(e);ctx.beginPath();ctx.moveTo(lx,ly);ctx.lineTo(p.x,p.y);ctx.stroke();lx=p.x;ly=p.y;});
  ['mouseup','mouseleave'].forEach(ev=>c.addEventListener(ev,()=>on=false));
  c.addEventListener('touchstart',e=>{e.preventDefault();on=true;const p=gp(e);lx=p.x;ly=p.y;},{passive:false});
  c.addEventListener('touchmove',e=>{if(!on)return;e.preventDefault();const p=gp(e);ctx.beginPath();ctx.moveTo(lx,ly);ctx.lineTo(p.x,p.y);ctx.stroke();lx=p.x;ly=p.y;},{passive:false});
  c.addEventListener('touchend',()=>on=false);
}
window.clrC=id=>{const c=document.getElementById(id);if(!c)return;c.getContext('2d').clearRect(0,0,c.width,c.height);};
function cvB64(id){const c=document.getElementById(id);return c?c.toDataURL('image/png'):'';}
function drawSig(id,src){if(!src)return;setTimeout(()=>{
  const c=document.getElementById(id);if(!c)return;
  const ctx=c.getContext('2d'),img=new Image();
  img.onload=()=>{const r=c.getBoundingClientRect(),dpr=window.devicePixelRatio||1;c.width=r.width*dpr;c.height=r.height*dpr;ctx.scale(dpr,dpr);ctx.drawImage(img,0,0,r.width,r.height);};
  img.src=src;
},400);}

// ── FILES ─────────────────────────────────────────
function addF(fs){[...fs].forEach(f=>{if(f.size>10*1024*1024){toast('⚠ '+f.name+' exceeds 10 MB');return;}if(!_files.find(x=>x.name===f.name))_files.push(f);});rndrF();}
function rndrF(){const fl=document.getElementById('B-fl');fl.innerHTML='';_files.forEach((f,i)=>{const sz=f.size>1024*1024?(f.size/1024/1024).toFixed(1)+' MB':(f.size/1024).toFixed(0)+' KB';const el=document.createElement('div');el.className='fitem';el.innerHTML=`<span>📄 <span class="fn">${f.name}</span><span class="fs">${sz}</span></span><button onclick="remF(${i})">✕</button>`;fl.appendChild(el);});}
window.remF=i=>{_files.splice(i,1);rndrF();};

// ── COPY & SHARE ──────────────────────────────────
function copyLnk(id){
  const txt=document.getElementById(id).textContent.trim();
  if(!txt||txt.length<30){toast('⚠ Generate a link first');return;}
  navigator.clipboard.writeText(txt).then(()=>toast('✓ Link copied to clipboard!')).catch(()=>{
    const ta=document.createElement('textarea');ta.value=txt;document.body.appendChild(ta);ta.select();document.execCommand('copy');document.body.removeChild(ta);toast('✓ Copied!');
  });
}
function waShare(id,type){
  const link=document.getElementById(id).textContent.trim();
  if(!link||link.length<30){toast('⚠ Generate the link first');return;}
  const msgs={
    tenant:'Hello, please complete the Solar Panel Permission Agreement:\n'+link,
    review:'Hi, I have completed the Solar Panel Permission Agreement. Please review and approve:\n'+link,
    final:'Solar Panel Permission Agreement — Final Record:\n'+link,
  };
  window.open('https://wa.me/?text='+encodeURIComponent(msgs[type]||link),'_blank');
}

// ── TOAST ─────────────────────────────────────────
let _tt;
function toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');clearTimeout(_tt);_tt=setTimeout(()=>t.classList.remove('show'),3400);}
</script>
