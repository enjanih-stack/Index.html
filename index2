<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Solar Panel Permission – Crestechnologies IS Ltd</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Source+Serif+4:ital,wght@0,300;0,400;0,600;1,300&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#1a1a1a;--gold:#b8860b;--gl:#d4a017;--cream:#faf7f2;
  --wg:#e8e4de;--rule:#c8bfb0;--red:#8b1a1a;--green:#1a5c2e;
  --sh:rgba(0,0,0,.08);--blue:#1a3a6b;
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:#e8e2d9;font-family:'Source Serif 4',Georgia,serif;color:var(--ink);min-height:100vh;padding:0 0 60px}

/* DEPLOY BANNER */
#deployBanner{background:linear-gradient(135deg,#1a1a1a,#2a2218);border-bottom:3px solid var(--gold);padding:12px 20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px}
#deployBanner p{font-size:.78rem;color:#e8d9b0;line-height:1.5}
#deployBanner strong{color:var(--gl)}
#deployBanner a{color:var(--gl);font-weight:700;text-decoration:none;border-bottom:1px dashed var(--gl)}
.deploy-steps{display:flex;gap:16px;flex-wrap:wrap;margin-top:6px}
.deploy-step{background:rgba(184,134,11,.15);border:1px solid rgba(184,134,11,.3);border-radius:3px;padding:5px 10px;font-size:.73rem;color:#e8d9b0;white-space:nowrap}
.deploy-step strong{color:var(--gl)}
#deployBanner .close-btn{background:none;border:1px solid rgba(184,134,11,.4);border-radius:3px;color:var(--gl);font-size:.72rem;cursor:pointer;padding:4px 10px;white-space:nowrap;font-family:inherit;letter-spacing:.06em}

/* LOADING */
#loadScreen{position:fixed;inset:0;background:#1a1a1a;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9999;transition:opacity .5s}
#loadScreen.hide{opacity:0;pointer-events:none}
.ls-logo{width:76px;height:76px;border-radius:50%;border:3px solid var(--gold);margin-bottom:14px;animation:pulse 1.5s infinite}
.ls-title{font-family:'Playfair Display',serif;color:#fff;font-size:1.05rem;letter-spacing:.06em;margin-bottom:4px}
.ls-sub{color:var(--gl);font-size:.7rem;letter-spacing:.14em;text-transform:uppercase;margin-bottom:22px}
.ls-bar{width:180px;height:3px;background:#333;border-radius:2px;overflow:hidden}
.ls-bar-fill{height:100%;background:linear-gradient(90deg,var(--gold),var(--gl));width:0;animation:loadbar 1s ease forwards .2s}
@keyframes loadbar{to{width:100%}}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(184,134,11,.4)}50%{box-shadow:0 0 0 10px rgba(184,134,11,0)}}

/* TOAST */
.toast{position:fixed;top:16px;left:50%;transform:translateX(-50%) translateY(-80px);background:#111;color:#fff;padding:11px 22px;border-radius:4px;font-size:.82rem;letter-spacing:.05em;z-index:9000;transition:transform .35s cubic-bezier(.34,1.56,.64,1);pointer-events:none;border-bottom:3px solid var(--gold);max-width:92vw;text-align:center}
.toast.show{transform:translateX(-50%) translateY(0)}

/* VIEWS */
.view{display:none;max-width:880px;margin:0 auto;padding:22px 14px 40px}
.view.active{display:block}

/* LETTERHEAD */
.lh{background:#fff;border-radius:4px 4px 0 0;overflow:hidden;box-shadow:0 2px 12px var(--sh)}
.lh-top{background:#111;display:flex;align-items:center;justify-content:space-between;padding:15px 26px;gap:14px;flex-wrap:wrap}
.lh-left{display:flex;align-items:center;gap:12px}
.lh-logo{width:54px;height:54px;border-radius:50%;border:2px solid var(--gold);object-fit:cover;flex-shrink:0}
.lh-co-name{font-family:'Playfair Display',serif;font-size:1.02rem;font-weight:700;color:#fff;letter-spacing:.04em}
.lh-co-sub{font-size:.64rem;color:var(--gl);letter-spacing:.12em;text-transform:uppercase;margin-top:2px}
.lh-right{text-align:right}
.lh-title-main{font-family:'Playfair Display',serif;font-size:.9rem;font-weight:700;color:#fff;line-height:1.3}
.lh-title-sub{font-size:.64rem;color:var(--gl);letter-spacing:.1em;text-transform:uppercase;margin-top:3px}
.lh-bar{height:4px;background:linear-gradient(90deg,var(--gold),var(--gl),var(--gold))}
.lh-addr{background:#f5f2ec;padding:6px 26px;display:flex;justify-content:space-between;font-size:.7rem;color:#5a5048;border-bottom:1px solid var(--rule);flex-wrap:wrap;gap:4px}
.sbar{display:flex;justify-content:space-between;align-items:center;padding:7px 26px;background:var(--cream);border-bottom:1px solid var(--rule);font-size:.68rem;letter-spacing:.07em;flex-wrap:wrap;gap:4px}
.sbar span{color:#6b6358}.sbar strong{color:var(--ink)}
.badge{display:inline-block;padding:2px 9px;border-radius:20px;font-size:.64rem;font-weight:700;letter-spacing:.1em}
.b-p{background:rgba(184,134,11,.12);color:var(--gold);border:1px solid rgba(184,134,11,.3)}
.b-s{background:rgba(26,58,107,.12);color:var(--blue);border:1px solid rgba(26,58,107,.3)}
.b-w{background:rgba(184,134,11,.15);color:#7a5a00;border:1px solid rgba(184,134,11,.4)}
.b-ok{background:rgba(26,92,46,.12);color:var(--green);border:1px solid rgba(26,92,46,.3)}
.b-no{background:rgba(139,26,26,.12);color:var(--red);border:1px solid rgba(139,26,26,.3)}

/* PAPER */
.paper{background:var(--cream);border-radius:0 0 4px 4px;box-shadow:0 2px 12px var(--sh)}
.pi{padding:26px 30px 34px}

/* SECTIONS */
.sec{margin-bottom:21px}
.sl{font-family:'Playfair Display',serif;font-size:.67rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);border-bottom:1px solid var(--rule);padding-bottom:5px;margin-bottom:11px}

/* FIELDS */
.fr{display:grid;gap:10px;margin-bottom:10px}
.c2{grid-template-columns:1fr 1fr}.c3{grid-template-columns:1fr 1fr 1fr}
.f{display:flex;flex-direction:column;gap:3px}
label{font-size:.67rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:#6b6358}
input[type=text],input[type=date],input[type=number],textarea{font-family:'Source Serif 4',serif;font-size:.85rem;background:#fff;border:1px solid var(--rule);border-bottom:2px solid var(--gold);border-radius:3px 3px 0 0;padding:7px 10px;color:var(--ink);transition:all .2s;width:100%}
input:focus,textarea:focus{outline:none;border-bottom-color:var(--gl);box-shadow:0 2px 0 var(--gl);background:#fffdf8}
input[readonly],textarea[readonly]{background:#f0ede8;color:#666;cursor:default;border-bottom-color:#bbb}
textarea{resize:vertical;min-height:60px}

/* CLAUSES */
.cb{background:#fff;border:1px solid var(--rule);border-left:4px solid var(--gold);border-radius:0 3px 3px 0;padding:10px 13px;margin-bottom:7px;font-size:.825rem;line-height:1.72;color:#2a2520}
.cb strong{color:var(--gold);font-weight:600}
.cb.w{border-left-color:var(--red);background:#fff9f9}.cb.w strong{color:var(--red)}
.cn{font-family:'Playfair Display',serif;font-size:.7rem;font-weight:700;color:var(--gold);text-transform:uppercase;letter-spacing:.1em;display:block;margin-bottom:2px}
.cn.r{color:var(--red)}

/* CHECKLIST */
.cklist{list-style:none;padding:0}
.cklist li{display:flex;align-items:flex-start;gap:9px;padding:5px 0;border-bottom:1px dashed var(--wg);font-size:.83rem;line-height:1.5}
.cklist li:last-child{border-bottom:none}
.cklist li input[type=checkbox]{width:15px;height:15px;margin-top:2px;accent-color:var(--gold);flex-shrink:0;cursor:pointer;border:none;border-bottom:none;box-shadow:none;padding:0}
.cl{text-transform:none!important;letter-spacing:0!important;font-size:.83rem!important;font-weight:400!important;color:var(--ink)!important;cursor:pointer}

/* FEE */
.fee-box{background:linear-gradient(135deg,#fdf9f0,#faf5e8);border:1px solid var(--gold);border-radius:4px;padding:12px 16px;margin-bottom:8px}
.fee-title{font-family:'Playfair Display',serif;font-size:.84rem;font-weight:700;color:var(--gold);margin-bottom:2px}
.fee-amt{font-family:'Playfair Display',serif;font-size:1.32rem;font-weight:700;color:var(--ink)}
.fee-box p{font-size:.78rem;color:#5a5048;line-height:1.6;margin-top:4px}

/* ATTACHMENTS */
.az{border:2px dashed var(--rule);border-radius:4px;padding:16px;text-align:center;cursor:pointer;transition:all .2s;background:#fff;position:relative}
.az:hover,.az.dv{border-color:var(--gold);background:#fffdf8}
.az input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;border:none;border-bottom:none;background:transparent;box-shadow:none;padding:0}
.az-icon{font-size:1.8rem;display:block;margin-bottom:4px}
.az p{font-size:.79rem;color:#7a7060;line-height:1.5}
.flist{margin-top:8px}
.fitem{display:flex;align-items:center;justify-content:space-between;background:#fff;border:1px solid var(--rule);border-radius:3px;padding:5px 10px;margin-bottom:4px;font-size:.77rem}
.fn{color:var(--green);font-weight:600}.fs{color:#9a9080;margin-left:5px}
.fitem button{background:none;border:none;color:var(--red);cursor:pointer;font-size:.92rem;padding:0 3px}

/* SIGNATURES */
.sig-block{background:#fff;border:1px solid var(--rule);border-radius:3px;overflow:hidden}
.sig-lbl{background:var(--wg);padding:6px 12px;font-size:.67rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:#6b6358;display:flex;justify-content:space-between;align-items:center}
.sig-lbl button{background:none;border:1px solid var(--rule);border-radius:2px;padding:2px 7px;font-size:.65rem;cursor:pointer;color:var(--red);font-family:inherit}
canvas{display:block;cursor:crosshair;touch-action:none;width:100%;height:100px;background:#fff}
canvas.ro{cursor:default}
.sig-ft{padding:4px 12px;font-size:.69rem;color:#9a9080;font-style:italic;border-top:1px dashed var(--rule)}

/* STEPS */
.steps-wrap{display:flex;align-items:center;margin-bottom:18px;padding:0 2px}
.step{display:flex;flex-direction:column;align-items:center;flex:1;position:relative}
.step:not(:last-child)::after{content:'';position:absolute;top:13px;left:58%;width:84%;height:2px;background:var(--rule);z-index:0}
.step.done::after{background:var(--gold)}
.step-dot{width:26px;height:26px;border-radius:50%;border:2px solid var(--rule);background:#fff;display:flex;align-items:center;justify-content:center;font-size:.73rem;font-weight:700;color:#aaa;z-index:1;position:relative;transition:all .3s}
.step.done .step-dot{border-color:var(--gold);background:var(--gold);color:#fff}
.step.active .step-dot{border-color:var(--gold);background:#fff;color:var(--gold);box-shadow:0 0 0 3px rgba(184,134,11,.2)}
.step-lbl{font-size:.6rem;letter-spacing:.07em;text-transform:uppercase;color:#9a9080;margin-top:5px;text-align:center}
.step.done .step-lbl,.step.active .step-lbl{color:var(--gold)}

/* BUTTONS */
.btn-row{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin-top:22px}
.btn{font-family:'Playfair Display',serif;font-size:.85rem;font-weight:700;letter-spacing:.07em;border:none;border-radius:3px;padding:12px 22px;cursor:pointer;transition:all .2s;text-transform:uppercase;white-space:nowrap}
.btn-gold{color:#fff;background:linear-gradient(135deg,#8b6914,var(--gold),#8b6914);background-size:200%;box-shadow:0 4px 14px rgba(184,134,11,.35)}
.btn-gold:hover{background-position:100%;transform:translateY(-1px)}
.btn-dk{color:var(--gl);background:#1a1a1a;box-shadow:0 3px 10px rgba(0,0,0,.3)}
.btn-dk:hover{background:#2a2520;transform:translateY(-1px)}
.btn-gr{color:#fff;background:var(--green);box-shadow:0 3px 10px rgba(26,92,46,.3)}
.btn-gr:hover{filter:brightness(1.12);transform:translateY(-1px)}
.btn-rd{color:#fff;background:var(--red);box-shadow:0 3px 10px rgba(139,26,26,.3)}
.btn-rd:hover{filter:brightness(1.12);transform:translateY(-1px)}
.btn-wa{color:#fff;background:#25D366;box-shadow:0 3px 10px rgba(37,211,102,.3)}
.btn-wa:hover{filter:brightness(1.08);transform:translateY(-1px)}

/* INFO BOXES */
.info-box{background:#fff;border:1px solid var(--rule);border-left:4px solid var(--blue);border-radius:0 3px 3px 0;padding:11px 13px;margin-bottom:10px;font-size:.82rem;line-height:1.7}
.info-box strong{color:var(--blue)}
.info-box.ok{border-left-color:var(--green)}.info-box.ok strong{color:var(--green)}
.info-box.warn{border-left-color:var(--gold)}.info-box.warn strong{color:#7a5a00}

/* LINK BOX */
.link-wrap{display:flex;gap:8px;align-items:stretch;margin-top:7px}
.link-txt{flex:1;font-family:'Source Serif 4',serif;font-size:.74rem;background:#f5f2ec;border:1px solid var(--rule);border-bottom:2px solid var(--gold);border-radius:3px 3px 0 0;padding:8px 10px;color:var(--ink);word-break:break-all;overflow-wrap:anywhere;user-select:all;cursor:text}
.link-copy{font-family:'Playfair Display',serif;font-size:.7rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;background:var(--gold);color:#fff;border:none;border-radius:3px;padding:0 12px;cursor:pointer;white-space:nowrap;transition:all .2s;flex-shrink:0}
.link-copy:hover{background:var(--gl)}

/* RADIO */
.radio-row{display:flex;gap:12px;margin-bottom:12px;flex-wrap:wrap}
.radio-opt{display:flex;align-items:center;gap:8px;cursor:pointer;padding:9px 14px;border:1px solid var(--rule);border-radius:3px;font-size:.83rem;transition:all .15s;flex:1;min-width:150px}
.radio-opt:has(input:checked){border-color:var(--gold);background:#fffdf8}
.radio-opt input[type=radio]{accent-color:var(--gold);width:15px;height:15px;border:none;border-bottom:none;box-shadow:none;padding:0;flex-shrink:0}

/* PRINT */
@media print{
  #deployBanner,#loadScreen,.btn-row,.az,.toast,.steps-wrap,.link-wrap,.link-copy,.info-box{display:none!important}
  body{background:#fff;padding:0}
  .view{display:block!important;padding:0;max-width:100%}
  .lh,.paper{box-shadow:none;border-radius:0}
  .pi{padding:14px}
  input,textarea{border:none!important;border-bottom:1px solid #aaa!important;background:transparent!important;box-shadow:none!important;padding:3px 2px!important}
  canvas{border-bottom:1px solid #aaa}
}
@media(max-width:580px){
  .pi{padding:16px 13px}
  .fr.c2,.fr.c3{grid-template-columns:1fr}
  .lh-top{flex-direction:column}.lh-right{text-align:left}
  .btn-row{flex-direction:column;align-items:stretch}
  .btn{text-align:center}
  .radio-row{flex-direction:column}
  #deployBanner .deploy-steps{display:none}
}
</style>
</head>
<body>

<!-- ═══ DEPLOYMENT GUIDE BANNER ═══ -->
<div id="deployBanner">
  <div>
    <p><strong>⚠ This file must be hosted online before links will work.</strong> A <code>file://</code> path only works on your own PC — tenants cannot open it.</p>
    <div class="deploy-steps">
      <div class="deploy-step"><strong>Option A — Easiest:</strong> Go to <a href="https://tiiny.host" target="_blank">tiiny.host</a> → Upload this HTML file → Get a free public link in 30 seconds</div>
      <div class="deploy-step"><strong>Option B:</strong> <a href="https://netlify.com/drop" target="_blank">netlify.com/drop</a> → Drag &amp; drop this file → Instant HTTPS link</div>
      <div class="deploy-step"><strong>Option C:</strong> Save to Google Drive → Right-click → Share → Anyone with link → Copy link</div>
    </div>
  </div>
  <button class="close-btn" onclick="document.getElementById('deployBanner').style.display='none'">✕ Dismiss</button>
</div>

<!-- LOADING -->
<div id="loadScreen">
  <img class="ls-logo" src="data:image/png;base64," alt="Logo">
  <div class="ls-title">Crestechnologies IS Ltd</div>
  <div class="ls-sub">Solar Permission System</div>
  <div class="ls-bar"><div class="ls-bar-fill"></div></div>
</div>

<div class="toast" id="toast"></div>


<!-- ═══════════════════════════════════════════════
     VIEW A — LANDLORD SETUP  (default view)
═══════════════════════════════════════════════ -->
<div class="view" id="vA">
<div class="lh">
  <div class="lh-top">
    <div class="lh-left">
      <img class="lh-logo" src="data:image/png;base64," alt="Logo">
      <div><div class="lh-co-name">Crestechnologies IS Ltd</div>
           <div class="lh-co-sub">Property &amp; Facility Services · Solar Permission</div></div>
    </div>
    <div class="lh-right">
      <div class="lh-title-main">Solar Panel Installation<br>Permission Agreement</div>
      <div class="lh-title-sub">Landlord Setup — Step 1 of 3</div>
    </div>
  </div>
  <div class="lh-bar"></div>
  <div class="lh-addr">
    <span>🏢 Crestechnologies IS Ltd</span>
    <span>📍 Ojodu, Ogun State, Nigeria · London, UK</span>
    <span>✉️ info@crestechnologies.com</span>
  </div>
  <div class="sbar">
    <span>Ref: <strong id="A-ref">—</strong></span>
    <span>Date: <strong id="A-date"></strong></span>
    <span class="badge b-p">STEP 1 — LANDLORD SETUP</span>
  </div>
</div>
<div class="paper"><div class="pi">

  <div class="steps-wrap">
    <div class="step active"><div class="step-dot">1</div><div class="step-lbl">Landlord Setup</div></div>
    <div class="step"><div class="step-dot">2</div><div class="step-lbl">Tenant Fills</div></div>
    <div class="step"><div class="step-dot">3</div><div class="step-lbl">Final Approval</div></div>
  </div>

  <div class="info-box">
    <strong>Landlord:</strong> Fill in the property and party details below. Click <em>"Generate Tenant Link"</em> — a shareable HTTPS link will appear. Send it to your tenant via WhatsApp or email. They complete their section and send you a review link.
  </div>

  <div class="sec">
    <div class="sl">§1 — Property &amp; Parties</div>
    <div class="fr">
      <div class="f"><label>Property Address <span style="color:var(--red)">*</span></label>
        <input type="text" id="A-addr" placeholder="Full property address including estate, city"></div>
    </div>
    <div class="fr c2">
      <div class="f"><label>Landlord Full Name <span style="color:var(--red)">*</span></label>
        <input type="text" id="A-llName" placeholder="Your full legal name"></div>
      <div class="f"><label>Landlord Phone / Email</label>
        <input type="text" id="A-llContact" placeholder="Contact details"></div>
    </div>
    <div class="fr c2">
      <div class="f"><label>Tenant Full Name <span style="color:var(--red)">*</span></label>
        <input type="text" id="A-teName" placeholder="Tenant full legal name"></div>
      <div class="f"><label>Tenant Phone / Email</label>
        <input type="text" id="A-teContact" placeholder="Tenant contact"></div>
    </div>
    <div class="fr c3">
      <div class="f"><label>Tenancy Start Date</label>
        <input type="date" id="A-tenDate"></div>
      <div class="f"><label>Approval Issue Date <span style="color:var(--red)">*</span></label>
        <input type="date" id="A-appDate"></div>
      <div class="f"><label>Approval Expiry</label>
        <input type="date" id="A-expDate"></div>
    </div>
  </div>

  <div class="sec">
    <div class="sl">§2 — Installation Parameters</div>
    <div class="fr c3">
      <div class="f"><label>Max Panels Permitted</label>
        <input type="number" id="A-panels" value="3" min="1" max="3"></div>
      <div class="f"><label>Max Weight kg (Fixed)</label>
        <input type="number" value="60" readonly></div>
      <div class="f"><label>Restricted Zones (if any)</label>
        <input type="text" id="A-restrict" placeholder="e.g. Front-facing roof excluded"></div>
    </div>
    <div class="fr">
      <div class="f"><label>Special Conditions / Notes for Tenant</label>
        <textarea id="A-note" placeholder="Any specific instructions for the tenant…"></textarea></div>
    </div>
  </div>

  <div class="sec">
    <div class="sl">Standard Terms Preview</div>
    <div class="cb w"><span class="cn r">Clause 3.1 — No Structural Penetration</span>No holes, drilling, or penetrations to roof, ceiling, or load-bearing structure. Non-invasive mounting only.</div>
    <div class="cb w"><span class="cn r">Clause 4.1 — Full Tenant Liability</span>Tenant bears full liability for all damage to building, persons, and animals during and after installation.</div>
    <div class="cb"><span class="cn">Clause 5 — Additional Caution Deposit: ₦100,000</span>Payable within 7 days of signing. Refundable on clean removal at end of tenancy.</div>
    <div class="cb w"><span class="cn r">Clause 6.1 — Maintenance Excluded</span>Maintenance, repairs, and upgrades require a separate written approval.</div>
  </div>

  <div class="btn-row">
    <button class="btn btn-gold" onclick="genTenantLink()">📤 Generate Tenant Link</button>
    <button class="btn btn-dk" onclick="window.print()">🖨️ Print</button>
  </div>

  <div id="A-result" style="display:none;margin-top:20px">
    <div class="info-box ok">
      <strong>✓ Tenant link ready!</strong> Copy it below and send to <strong id="A-teName-out"></strong> via WhatsApp, SMS or email. Once they submit, they will send you a Landlord Review link.
    </div>
    <div style="font-size:.69rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:#6b6358;margin-bottom:6px">Tenant Form Link:</div>
    <div class="link-wrap">
      <div class="link-txt" id="A-link"></div>
      <button class="link-copy" onclick="copyLnk('A-link')">Copy</button>
    </div>
    <div class="btn-row" style="margin-top:12px">
      <button class="btn btn-wa" onclick="waShare('A-link','tenant')">💬 Share via WhatsApp</button>
    </div>
  </div>

</div></div>
</div><!-- /vA -->


<!-- ═══════════════════════════════════════════════
     VIEW B — TENANT FILLS FORM
═══════════════════════════════════════════════ -->
<div class="view" id="vB">
<div class="lh">
  <div class="lh-top">
